#!/usr/bin/env python3
"""UmaOS Cursor Theme Switcher — Qt6/QML GUI with kdialog & text fallbacks."""

import os
import sys
import struct
import subprocess
import shutil
import re


# ── Theme discovery ────────────────────────────────────────────────────────────

ICON_DIR = "/usr/share/icons"
PREVIEW_CACHE_DIR = os.path.join(
    os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")),
    "umao-cursor-switcher", "previews",
)


# ── X11 cursor preview extraction ─────────────────────────────────────────────

def extract_cursor_png(cursor_path: str, size: int = 32) -> bytes | None:
    """Extract a single frame from an X11 cursor file as raw RGBA pixels.

    Returns (width, height, rgba_bytes) or None on failure.
    """
    try:
        with open(cursor_path, "rb") as f:
            magic = f.read(4)
            if magic != b"Xcur":
                return None
            header_size, version, ntoc = struct.unpack("<III", f.read(12))

            # The TOC starts at header_size, not necessarily right after the
            # 16 bytes we just read; honour the declared header size so files
            # with a larger header are not misparsed.
            f.seek(header_size)

            # Read TOC entries — type 0xfffd0002 = image
            images = []
            for _ in range(ntoc):
                etype, esubtype, epos = struct.unpack("<III", f.read(12))
                if etype == 0xFFFD0002:
                    images.append((esubtype, epos))  # (nominal_size, file_pos)

            if not images:
                return None

            # Prefer an exact size match, then the closest LARGER image
            # (downscaling looks better than upscaling). The previous key
            # broke ties toward the smaller image, contradicting its comment.
            images.sort(key=lambda x: (abs(x[0] - size), -x[0]))
            _, pos = images[0]

            # Read image chunk
            f.seek(pos)
            chunk_header_size, chunk_type, chunk_subtype, chunk_version = struct.unpack("<IIII", f.read(16))
            width, height, xhot, yhot, delay = struct.unpack("<IIIII", f.read(20))

            # width/height come straight from the file; a malformed cursor
            # could otherwise ask for a multi-GB read (MemoryError, which the
            # handler below does not catch). Xcursor images are <= 256px.
            if not (0 < width <= 256 and 0 < height <= 256):
                return None

            pixels = f.read(width * height * 4)  # ARGB
            if len(pixels) != width * height * 4:
                return None

            return (width, height, pixels)
    except (OSError, struct.error, MemoryError, ValueError):
        return None


def write_png(path: str, width: int, height: int, argb_pixels: bytes) -> bool:
    """Write ARGB pixel data as a PNG file (pure Python, no dependencies)."""
    import zlib

    # Convert ARGB to RGBA.
    # Xcursor stores PREMULTIPLIED alpha; PNG expects straight alpha. Emitting
    # the premultiplied values directly darkened every antialiased edge, so
    # un-premultiply as we go.
    rgba = bytearray(len(argb_pixels))
    for i in range(0, len(argb_pixels), 4):
        b, g, r, a = argb_pixels[i], argb_pixels[i + 1], argb_pixels[i + 2], argb_pixels[i + 3]
        if a == 0:
            r = g = b = 0
        elif a != 255:
            r = min(255, (r * 255 + a // 2) // a)
            g = min(255, (g * 255 + a // 2) // a)
            b = min(255, (b * 255 + a // 2) // a)
        rgba[i] = r
        rgba[i + 1] = g
        rgba[i + 2] = b
        rgba[i + 3] = a

    # Build PNG
    def chunk(ctype: bytes, data: bytes) -> bytes:
        c = ctype + data
        crc = zlib.crc32(c) & 0xFFFFFFFF
        return struct.pack(">I", len(data)) + c + struct.pack(">I", crc)

    raw_data = bytearray()
    stride = width * 4
    for y in range(height):
        raw_data.append(0)  # filter byte: None
        raw_data.extend(rgba[y * stride:(y + 1) * stride])

    # Write to a temp file and rename: writing straight to the final path meant
    # an interrupted write left a truncated PNG that the isfile() cache check
    # then served forever.
    tmp_path = f"{path}.tmp.{os.getpid()}"
    try:
        with open(tmp_path, "wb") as f:
            f.write(b"\x89PNG\r\n\x1a\n")
            f.write(chunk(b"IHDR", struct.pack(">IIBBBBB", width, height, 8, 6, 0, 0, 0)))
            f.write(chunk(b"IDAT", zlib.compress(bytes(raw_data))))
            f.write(chunk(b"IEND", b""))
        os.replace(tmp_path, path)
        return True
    except OSError:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        return False


def get_preview_path(theme_id: str) -> str:
    """Get or generate a cursor preview PNG for a theme. Returns path or empty."""
    # An unwritable HOME/XDG_CACHE_HOME raised straight out of here, taking
    # discover_themes() — and therefore the whole app, in all three modes —
    # down at startup. Previews are cosmetic; degrade instead.
    try:
        os.makedirs(PREVIEW_CACHE_DIR, exist_ok=True)
    except OSError:
        return ""
    png_path = os.path.join(PREVIEW_CACHE_DIR, f"{theme_id}.png")

    if os.path.isfile(png_path):
        return png_path

    # Try common cursor names for preview
    cursors_dir = os.path.join(ICON_DIR, theme_id, "cursors")
    for name in ("left_ptr", "default", "arrow", "top_left_arrow"):
        cursor_file = os.path.join(cursors_dir, name)
        if not os.path.isfile(cursor_file):
            continue
        result = extract_cursor_png(cursor_file, size=32)
        if result:
            width, height, pixels = result
            if write_png(png_path, width, height, pixels):
                return png_path

    return ""


def friendly_name(theme_id: str) -> str:
    """Human-readable name for an installed cursor theme.

    Prefer the theme's own index.theme `Name=` (e.g. "[pixloen] Mejiro McQueen
    v1.7"), which carries the artist's real capitalization. Deriving the name
    from the directory instead forced a str.title() call that mangled
    intercaps — "pixloen-mejiro-mcqueen-v1.7" rendered as "Mejiro Mcqueen".
    """
    idx = os.path.join(ICON_DIR, theme_id, "index.theme")
    raw = ""
    try:
        with open(idx) as f:
            for line in f:
                if line.startswith("Name="):
                    raw = line.split("=", 1)[1].strip()
                    break
    except OSError:
        raw = ""

    if raw:
        # "[pixloen] Mejiro McQueen v1.7" -> "Mejiro McQueen"
        name = re.sub(r"^\[[^\]]*\]\s*", "", raw)
        name = re.sub(r"\s+v\d+(\.\d+)*$", "", name).strip()
        if name:
            return name

    # Fallback: derive from the directory name.
    name = theme_id.removeprefix("pixloen-")
    name = re.sub(r"-v\d+(\.\d+)*$", "", name)
    return name.replace("-", " ").title()


def discover_themes() -> list[dict]:
    """Find all pixloen-* cursor themes and return sorted list of dicts."""
    themes = []
    if not os.path.isdir(ICON_DIR):
        return themes

    for entry in sorted(os.listdir(ICON_DIR)):
        if not entry.startswith("pixloen-"):
            continue
        cursors_dir = os.path.join(ICON_DIR, entry, "cursors")
        if not os.path.isdir(cursors_dir):
            continue

        name = friendly_name(entry)

        themes.append({
            "themeId": entry,
            "displayName": name,
            "preview": get_preview_path(entry),
        })

    return themes


def get_current_theme() -> str:
    """Read the current cursor theme from KDE config."""
    rc = os.path.expanduser("~/.config/kcminputrc")
    if not os.path.isfile(rc):
        return ""
    try:
        with open(rc) as f:
            for line in f:
                if line.startswith("cursorTheme="):
                    return line.strip().split("=", 1)[1]
    except OSError:
        pass
    return ""


def apply_theme(theme_id: str) -> tuple[bool, str]:
    """Apply cursor theme to KDE, GTK, and X11.

    Returns (ok, message). Callers must not assume success: this used to
    return None and swallow every failure, so the GUI showed "Cursor Applied!"
    even when the apply had raised or partially failed.

    plasma-apply-cursortheme is the supported Plasma 5.23+/6 entry point: it
    updates the config *and* notifies the running session, so the cursor
    actually changes without a re-login. The kwriteconfig/KWin-reconfigure
    path below only rewrites config files, which is why the old
    implementation appeared to do nothing until the user logged out.
    """
    applied_live = False
    if shutil.which("plasma-apply-cursortheme"):
        r = subprocess.run(
            ["plasma-apply-cursortheme", theme_id],
            capture_output=True, text=True,
        )
        applied_live = r.returncode == 0

    # KDE via kwriteconfig — still written as a fallback (and to cover the
    # case where plasma-apply-cursortheme is unavailable or failed).
    for cmd in ("kwriteconfig6", "kwriteconfig5"):
        if shutil.which(cmd):
            subprocess.run(
                [cmd, "--file", "kcminputrc", "--group", "Mouse",
                 "--key", "cursorTheme", theme_id],
                capture_output=True,
            )
            break

    # GTK 3.0 / 4.0.
    # The old code only re.sub'd an existing gtk-cursor-theme-name line: with
    # no match re.sub is a silent no-op, and a missing settings.ini was skipped
    # entirely — so GTK apps were usually never updated at all. Create the file
    # and insert the key when absent.
    home = os.path.expanduser("~")
    for gtk_ver in ("gtk-3.0", "gtk-4.0"):
        cfg_dir = os.path.join(home, ".config", gtk_ver)
        cfg = os.path.join(cfg_dir, "settings.ini")
        try:
            content = ""
            if os.path.isfile(cfg):
                with open(cfg) as f:
                    content = f.read()

            if re.search(r"^gtk-cursor-theme-name=", content, flags=re.MULTILINE):
                content = re.sub(
                    r"^gtk-cursor-theme-name=.*$",
                    f"gtk-cursor-theme-name={theme_id}",
                    content,
                    flags=re.MULTILINE,
                )
            elif re.search(r"^\[Settings\]", content, flags=re.MULTILINE):
                content = re.sub(
                    r"^\[Settings\]$",
                    f"[Settings]\ngtk-cursor-theme-name={theme_id}",
                    content,
                    count=1,
                    flags=re.MULTILINE,
                )
            else:
                if content and not content.endswith("\n"):
                    content += "\n"
                content += f"[Settings]\ngtk-cursor-theme-name={theme_id}\n"

            os.makedirs(cfg_dir, exist_ok=True)
            with open(cfg, "w") as f:
                f.write(content)
        except OSError:
            pass

    # X11 default cursor. This write was unguarded: a failure raised mid-apply
    # (leaving a half-applied state) while the GUI still showed success.
    default_dir = os.path.join(home, ".icons", "default")
    try:
        os.makedirs(default_dir, exist_ok=True)
        with open(os.path.join(default_dir, "index.theme"), "w") as f:
            f.write(f"[Icon Theme]\nInherits={theme_id}\n")
    except OSError as e:
        return False, f"Could not write {default_dir}/index.theme: {e}"

    # Reconfigure KWin so the running session picks the change up. Failures
    # here are not fatal (plasma-apply-cursortheme above already notified the
    # session when available), but they were previously swallowed entirely.
    for qdbus_cmd in ("qdbus6", "qdbus-qt6", "qdbus"):
        if shutil.which(qdbus_cmd):
            r = subprocess.run(
                [qdbus_cmd, "org.kde.KWin", "/KWin", "reconfigure"],
                capture_output=True,
            )
            if r.returncode != 0 and not applied_live:
                # Only worth surfacing if nothing else refreshed the session.
                return True, "Applied, but the running session may need a re-login to pick it up."
            break

    return True, ""


# ── Helpers ────────────────────────────────────────────────────────────────────

def has_display() -> bool:
    return bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))


# ═══════════════════════════════════════════════════════════════════════════════
# QML GUI mode (PyQt6)
# ═══════════════════════════════════════════════════════════════════════════════

def run_qml() -> None:
    from PyQt6.QtCore import QObject, QUrl, pyqtSignal, pyqtSlot, pyqtProperty
    from PyQt6.QtGui import QGuiApplication, QIcon
    from PyQt6.QtQml import QQmlApplicationEngine

    class CursorBackend(QObject):
        themeApplied = pyqtSignal(str, arguments=["themeId"])
        # applyTheme can fail (unwritable ~/.icons, missing kwriteconfig);
        # without a failure signal the UI showed "Cursor Applied!" regardless.
        themeApplyFailed = pyqtSignal(str, arguments=["error"])
        currentThemeChanged = pyqtSignal()

        def __init__(self, parent=None):
            super().__init__(parent)
            self._themes = discover_themes()
            self._current = get_current_theme()

        @pyqtProperty("QVariantList", constant=True)
        def themes(self):
            return self._themes

        # NOT constant: applyTheme mutates _current, so a constant property
        # left every QML binding that reads it (the Active badge,
        # hasNewSelection) silently stale after an apply.
        @pyqtProperty(str, notify=currentThemeChanged)
        def currentTheme(self):
            return self._current

        @pyqtSlot(str)
        def applyTheme(self, theme_id):
            ok, err = apply_theme(theme_id)
            if not ok:
                self.themeApplyFailed.emit(err)
                return
            self._current = theme_id
            self.currentThemeChanged.emit()
            self.themeApplied.emit(theme_id)

    app = QGuiApplication(sys.argv)
    app.setApplicationName("UmaOS Cursor Switcher")

    icon_path = "/usr/share/umaos/cursor-switcher/icon.png"
    if os.path.exists(icon_path):
        app.setWindowIcon(QIcon(icon_path))

    engine = QQmlApplicationEngine()
    backend = CursorBackend()
    engine.rootContext().setContextProperty("backend", backend)

    qml_dir = "/usr/share/umaos/cursor-switcher"
    engine.addImportPath(qml_dir)
    engine.load(QUrl.fromLocalFile(os.path.join(qml_dir, "main.qml")))

    if not engine.rootObjects():
        print("Error: Failed to load QML interface.", file=sys.stderr)
        sys.exit(1)

    sys.exit(app.exec())


# ═══════════════════════════════════════════════════════════════════════════════
# kdialog fallback
# ═══════════════════════════════════════════════════════════════════════════════

def run_kdialog() -> None:
    TITLE = "UmaOS Cursor Switcher"
    # kdialog --icon expects a themed icon NAME, not a path; the path used
    # before did not exist in the repo or the package anyway.
    ICON = "input-mouse"
    themes = discover_themes()
    current = get_current_theme()

    if not themes:
        subprocess.run(
            ["kdialog", "--icon", ICON, "--title", TITLE,
             "--sorry", "No pixloen cursor themes found."],
            capture_output=True,
        )
        return

    args = []
    for t in themes:
        state = "on" if t["themeId"] == current else "off"
        args += [t["themeId"], t["displayName"], state]

    result = subprocess.run(
        ["kdialog", "--icon", ICON, "--title", TITLE,
         "--radiolist", "Choose a cursor theme:"] + args,
        capture_output=True, text=True,
    )

    if result.returncode != 0 or not result.stdout.strip():
        return

    selected = result.stdout.strip().replace('"', '')
    ok, err = apply_theme(selected)
    if not ok:
        subprocess.run(["kdialog", "--icon", ICON, "--title", TITLE, "--error", err],
                       capture_output=True)
        return

    # Find display name
    name = selected
    for t in themes:
        if t["themeId"] == selected:
            name = t["displayName"]
            break

    subprocess.run(
        ["kdialog", "--icon", ICON, "--title", TITLE,
         "--passivepopup", f"{name} cursor is now active!", "5"],
        capture_output=True,
    )


# ═══════════════════════════════════════════════════════════════════════════════
# Text fallback
# ═══════════════════════════════════════════════════════════════════════════════

def run_text() -> None:
    themes = discover_themes()
    current = get_current_theme()

    if not themes:
        print("No pixloen cursor themes found.")
        return

    print()
    print("  UmaOS Cursor Theme Switcher")
    print("  " + "\u2501" * 30)
    print()

    for i, t in enumerate(themes):
        marker = "\u25b8 " if t["themeId"] == current else "  "
        print(f"  {marker}{i + 1:2d}) {t['displayName']}")

    print()
    try:
        choice = input(f"  Choose cursor (1-{len(themes)}): ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if not choice.isdigit() or not (1 <= int(choice) <= len(themes)):
        print("  Invalid choice.")
        return

    selected = themes[int(choice) - 1]
    print(f"\n  Applying: {selected['displayName']} ({selected['themeId']})")
    ok, err = apply_theme(selected["themeId"])
    if not ok:
        print(f"  ERROR: {err}")
        print()
        return
    print(f"  Done! {selected['displayName']} cursor is now active.")
    if err:
        print(f"  Note: {err}")
    print()


# ═══════════════════════════════════════════════════════════════════════════════
# Entry point
# ═══════════════════════════════════════════════════════════════════════════════

def main() -> None:
    if "--text" in sys.argv:
        return run_text()

    if not has_display():
        return run_text()

    try:
        import PyQt6.QtCore  # noqa: F401
        return run_qml()
    except ImportError:
        pass

    if shutil.which("kdialog"):
        return run_kdialog()

    return run_text()


if __name__ == "__main__":
    main()
